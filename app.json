{
  "expo": {
    "name": "Orbacle",
    "slug": "orbacle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.orbacle.app"
    },
    "android": {
      "icon": "./assets/android-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.orbacle.app",
      "permissions": []
    },
    "plugins": [
      "expo-asset",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "6b8b9d97-1af3-42d5-b60f-8fdb7da51de4"
      }
    }
  }
}
